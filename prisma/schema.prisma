// Sistema de Faturação Certificado pela AT
// Schema completo conforme requisitos fiscais portugueses

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// EMPRESA E CONFIGURAÇÕES
// ============================================

model Empresa {
  id                    String    @id @default(cuid())
  nome                  String
  nif                   String    @unique
  morada                String
  codigoPostal          String
  localidade            String
  email                 String?
  telefone              String?
  website               String?

  // Dados fiscais adicionais
  conservatoria         String?   // Conservatória do Registo Comercial
  capitalSocial         String?

  // Logótipo
  logo                  String?   // Base64 ou URL

  // Configurações do sistema
  configurado           Boolean   @default(false)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relacionamentos
  utilizadores          Utilizador[]
  series                Serie[]
  taxasIVA              TaxaIVA[]
  artigos               Artigo[]
  clientes              Cliente[]
  documentos            Documento[]
  fornecedores          Fornecedor[]
  armazens              Armazem[]
  faturasCompra         FaturaCompra[]
  encomendasCliente     EncomendaCliente[]
  subscricoes           Subscricao[]
  movimentosBancarios   MovimentoBancario[]
  apiKeys               ApiKey[]
  webhooks              WebhookConfig[]
}

model Utilizador {
  id            String    @id @default(cuid())
  nome          String
  email         String    @unique
  passwordHash  String
  perfil        String    @default("OPERADOR") // ADMIN, GESTOR, OPERADOR, CONSULTA
  ativo         Boolean   @default(true)
  ultimoAcesso  DateTime?

  empresaId     String?
  empresa       Empresa?  @relation(fields: [empresaId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relacionamentos
  auditoria     Auditoria[]
  documentos    Documento[]

  @@index([empresaId])
}

// ============================================
// ENTIDADES (CLIENTES E FORNECEDORES)
// ============================================

model Cliente {
  id            String    @id @default(cuid())
  codigo        String    @unique
  nome          String
  nif           String    @unique
  morada        String
  codigoPostal  String
  localidade    String
  pais          String    @default("PT")
  email         String?
  telefone      String?

  empresaId     String?
  empresa       Empresa?  @relation(fields: [empresaId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relacionamentos
  documentos    Documento[]
  orcamentos    Orcamento[]
  encomendas    EncomendaCliente[]
  subscricoes   Subscricao[]

  @@index([empresaId])
}

model Fornecedor {
  id            String    @id @default(cuid())
  codigo        String    @unique
  nome          String
  nif           String    @unique
  morada        String
  codigoPostal  String
  localidade    String
  pais          String    @default("PT")
  email         String?
  telefone      String?
  iban          String?

  empresaId     String?
  empresa       Empresa?  @relation(fields: [empresaId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  faturasCompra FaturaCompra[]

  @@index([empresaId])
}

// ============================================
// ARTIGOS E STOCK
// ============================================

enum TipoArtigo {
  PRODUTO
  SERVICO
}

model Artigo {
  id            String    @id @default(cuid())
  codigo        String    @unique
  descricao     String
  tipo          TipoArtigo @default(PRODUTO)
  unidade       String    @default("UNI")
  precoUnitario Float

  taxaIVAId     String
  taxaIVA       TaxaIVA   @relation(fields: [taxaIVAId], references: [id])

  controlaStock Boolean   @default(true)

  empresaId     String?
  empresa       Empresa?  @relation(fields: [empresaId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relacionamentos
  stocks        ArtigoArmazemStock[]
  movimentos    StockMovement[]
  linhasDoc     LinhaDocumento[]
  linhasOrc     LinhaOrcamento[]
  linhasEnc     LinhaEncomendaCliente[]
  linhasSub     LinhaSubscricao[]
  linhasFC      LinhaFaturaCompra[]

  @@index([empresaId])
}

model Armazem {
  id            String    @id @default(cuid())
  codigo        String    @unique
  nome          String
  morada        String?
  codigoPostal  String?
  localidade    String?
  principal     Boolean   @default(false)
  ativo         Boolean   @default(true)
  
  empresaId     String?
  empresa       Empresa?  @relation(fields: [empresaId], references: [id])

  stocks        ArtigoArmazemStock[]
  movimentos    StockMovement[]

  @@index([empresaId])
}

model ArtigoArmazemStock {
  id            String    @id @default(cuid())
  artigoId      String
  armazemId     String
  quantidade    Float     @default(0)
  stockMinimo   Float     @default(0)
  stockMaximo   Float?

  artigo        Artigo    @relation(fields: [artigoId], references: [id], onDelete: Cascade)
  armazem       Armazem   @relation(fields: [armazemId], references: [id], onDelete: Cascade)

  @@unique([artigoId, armazemId])
}

model StockMovement {
  id            String    @id @default(cuid())
  artigoId      String
  armazemId     String
  tipo          String    // ENTRADA, SAIDA, TRANSFERENCIA, AJUSTE
  quantidade    Float
  data          DateTime  @default(now())
  documentoRef  String?   // Referência a fatura, guia, etc
  observacoes   String?

  artigo        Artigo    @relation(fields: [artigoId], references: [id])
  armazem       Armazem   @relation(fields: [armazemId], references: [id])

  @@index([artigoId])
  @@index([armazemId])
}

// ============================================
// FISCALIDADE E CONFIGURAÇÃO AT
// ============================================

model TaxaIVA {
  id            String    @id @default(cuid())
  codigo        String    // NOR, INT, RED, ISE
  descricao     String
  percentagem   Float
  ativo         Boolean   @default(true)

  empresaId     String?
  empresa       Empresa?  @relation(fields: [empresaId], references: [id])

  artigos       Artigo[]

  @@index([empresaId])
}

model IsencaoIVA {
  id            String    @id @default(cuid())
  codigo        String    // Ex: M01
  descricao     String
  motivo        String
  ativo         Boolean   @default(true)
}

model Serie {
  id                String        @id @default(cuid())
  nome              String
  prefixo           String        // Ex: FT 2024/
  ano               Int
  numeroAtual       Int           @default(0)
  tipoDocumento     TipoDocumento
  ativa             Boolean       @default(true)
  principal         Boolean       @default(false)

  // AT Certification fields
  codigoValidacaoAT String?       // Código de validação atribuído pela AT

  empresaId         String?
  empresa           Empresa?      @relation(fields: [empresaId], references: [id])

  documentos        Documento[]
  subscricoes       Subscricao[]

  @@index([empresaId])
}

// ============================================
// DOCUMENTOS DE VENDA
// ============================================

enum TipoDocumento {
  FATURA
  FATURA_RECIBO
  NOTA_CREDITO
  GUIA_TRANSPORTE
  ORCAMENTO
}

model Documento {
  id                    String        @id @default(cuid())
  numero                Int           // Número sequencial dentro da série
  numeroFormatado       String        @unique // Ex: "FT 2024/1"
  tipo                  TipoDocumento
  serieId               String

  clienteId             String
  utilizadorId          String
  empresaId             String?
  
  // Snapshot dos dados do cliente no momento da emissão
  clienteNome           String
  clienteNif            String
  clienteMorada         String
  clienteCodigoPostal   String
  clienteLocalidade     String
  
  // Snapshot dos dados da empresa
  empresaNome           String
  empresaNif            String
  empresaMorada         String
  empresaCodigoPostal   String
  empresaLocalidade     String
  
  dataEmissao           DateTime      @default(now())
  dataVencimento        DateTime?
  
  // Valores Totais
  totalBase             Float
  totalIVA              Float
  totalLiquido          Float
  
  // Assinatura AT (Hash)
  hash                  String        // SHA1 base64 hash da linha de assinatura
  hashDocumentoAnterior String?
  atcud                 String?       // Código ATCUD obrigatório
  
  estado                String        @default("RASCUNHO") // RASCUNHO, EMITIDO, ANULADO
  estadoPagamento       String        @default("PENDENTE") // PENDENTE, PARCIAL, PAGO
  valorPago             Float         @default(0)

  accessKey             String?       @default(uuid()) // Chave para acesso público sem login

  observacoes           String?
  dataCriacao           DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relacionamentos
  empresa               Empresa?      @relation(fields: [empresaId], references: [id])
  serie                 Serie         @relation(fields: [serieId], references: [id])
  cliente               Cliente       @relation(fields: [clienteId], references: [id])
  utilizador            Utilizador    @relation(fields: [utilizadorId], references: [id])
  linhas                LinhaDocumento[]
  pagamentos            Pagamento[]

  @@index([serieId])
  @@index([clienteId])
  @@index([utilizadorId])
  @@index([empresaId])
  @@index([dataEmissao])
}

model LinhaDocumento {
  id                    String     @id @default(cuid())
  documentoId           String
  artigoId              String?
  
  ordem                 Int        @default(1)
  codigoArtigo          String
  descricaoArtigo       String
  quantidade            Float
  precoUnitario         Float
  desconto              Float      @default(0)
  
  taxaIVAId             String
  taxaIVAPercentagem    Float
  valorIVA              Float
  base                  Float
  
  documento             Documento  @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  artigo                Artigo?    @relation(fields: [artigoId], references: [id])

  @@index([documentoId])
  @@index([artigoId])
}

enum MetodoPagamento {
  NUMERARIO
  MULTIBANCO
  TRANSFERENCIA
  MBWAY
  STRIPE
  OUTRO
}

model Pagamento {
  id            String          @id @default(cuid())
  documentoId   String
  valor         Float
  data          DateTime        @default(now())
  metodo        MetodoPagamento
  referencia    String?
  
  documento     Documento       @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  movimentoBancario MovimentoBancario?

  @@index([documentoId])
}

// ============================================
// AUDITORIA E LOGS
// ============================================

model Auditoria {
  id            String    @id @default(cuid())
  data          DateTime  @default(now())
  utilizadorId  String
  acao          String    // CREATE, UPDATE, DELETE, EMIT, ANUL
  entidade      String    // DOCUMENTO, CLIENTE, ARTIGO, etc
  entidadeId    String
  valorAntigo   String?   // JSON
  valorNovo     String?   // JSON
  ip            String?
  
  utilizador    Utilizador @relation(fields: [utilizadorId], references: [id])

  @@index([utilizadorId])
  @@index([entidade, entidadeId])
}

// ============================================
// ORÇAMENTOS E PROPOSTAS
// ============================================

enum EstadoOrcamento {
  RASCUNHO
  ENVIADO
  ACEITE
  REJEITADO
  EXPIRADO
  CONVERTIDO
}

model Orcamento {
  id                    String          @id @default(cuid())
  numero                Int             // Número sequencial
  numeroFormatado       String          @unique // Ex: "ORC 2024/1"
  
  clienteId             String
  empresaId             String?
  
  clienteNome           String
  clienteNif            String
  clienteMorada         String
  clienteCodigoPostal   String
  clienteLocalidade     String
  
  dataEmissao           DateTime        @default(now())
  dataValidade          DateTime
  
  totalBase             Float           @default(0)
  totalIVA              Float           @default(0)
  totalLiquido          Float           @default(0)
  
  estado                EstadoOrcamento @default(RASCUNHO)
  observacoes           String?
  
  utilizadorId          String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  cliente               Cliente         @relation(fields: [clienteId], references: [id])
  linhas                LinhaOrcamento[]

  @@index([clienteId])
  @@index([estado])
}

model LinhaOrcamento {
  id                    String     @id @default(cuid())
  orcamentoId           String
  artigoId              String?
  
  codigoArtigo          String
  descricaoArtigo       String
  
  // Quantidades e preços
  quantidade            Float
  precoUnitario         Float
  desconto              Float      @default(0)
  
  // IVA
  taxaIVAId             String
  taxaIVAPercentagem    Float
  
  // Totais da linha
  base                  Float      // quantidade * precoUnitario - desconto
  valorIVA              Float      // base * taxaIVA
  
  ordem                 Int        @default(1)
  observacoes           String?
  
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  orcamento             Orcamento  @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  artigo                Artigo?    @relation(fields: [artigoId], references: [id])

  @@index([orcamentoId])
  @@index([artigoId])
}

// ============================================
// FATURAS DE COMPRA (FORNECEDORES)
// ============================================

enum EstadoPagamento {
  PENDENTE
  PARCIAL
  PAGO
}

model FaturaCompra {
  id                    String                @id @default(cuid())
  numero                String                // Número da fatura do fornecedor
  fornecedorId          String
  empresaId             String?

  // Dados do fornecedor no momento da criação
  fornecedorNome        String
  fornecedorNif         String

  // Datas
  dataEmissao           DateTime
  dataVencimento        DateTime?

  // Totais
  totalBase             Float                 @default(0)
  totalIVA              Float                 @default(0)
  totalLiquido          Float                 @default(0)

  // Estado
  estadoPagamento       EstadoPagamento       @default(PENDENTE)
  valorPago             Float                 @default(0)

  observacoes           String?

  utilizadorId          String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  empresa               Empresa?              @relation(fields: [empresaId], references: [id])
  fornecedor            Fornecedor            @relation(fields: [fornecedorId], references: [id])
  linhas                LinhaFaturaCompra[]
  pagamentos            PagamentoCompra[]

  @@index([fornecedorId])
  @@index([dataEmissao])
}

model LinhaFaturaCompra {
  id                    String           @id @default(cuid())
  faturaCompraId        String
  artigoId              String?

  descricao             String
  quantidade            Float
  precoUnitario         Float
  desconto              Float            @default(0)

  taxaIVAPercentagem    Float

  base                  Float
  valorIVA              Float

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  faturaCompra          FaturaCompra     @relation(fields: [faturaCompraId], references: [id], onDelete: Cascade)
  artigo                Artigo?          @relation(fields: [artigoId], references: [id])
}

model PagamentoCompra {
  id                    String           @id @default(cuid())
  faturaCompraId        String
  valor                 Float
  data                  DateTime         @default(now())
  metodo                MetodoPagamento
  referencia            String?

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  faturaCompra          FaturaCompra     @relation(fields: [faturaCompraId], references: [id], onDelete: Cascade)
}

// ============================================
// ENCOMENDAS DE CLIENTE (SALES ORDERS)
// ============================================

enum EstadoEncomendaCliente {
  RASCUNHO
  CONFIRMADA
  EM_PREPARACAO
  FATURADA
  CANCELADA
}

model EncomendaCliente {
  id                    String                 @id @default(cuid())
  numero                Int                    // Número sequencial
  numeroFormatado       String                 // "ENC 2024/00001"

  clienteId             String
  empresaId             String?
  clienteNome           String
  clienteNif            String

  dataEncomenda         DateTime               @default(now())
  dataEntregaPrevista   DateTime?

  totalBase             Float                  @default(0)
  totalIVA              Float                  @default(0)
  totalLiquido          Float                  @default(0)

  estado                EstadoEncomendaCliente @default(RASCUNHO)

  documentoId           String?                // Fatura gerada

  observacoes           String?

  utilizadorId          String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  empresa               Empresa?               @relation(fields: [empresaId], references: [id])
  cliente               Cliente                @relation(fields: [clienteId], references: [id])
  linhas                LinhaEncomendaCliente[]

  @@index([clienteId])
  @@index([estado])
}

model LinhaEncomendaCliente {
  id                    String           @id @default(cuid())
  encomendaId           String
  artigoId              String?

  codigoArtigo          String
  descricaoArtigo       String

  quantidade            Float
  precoUnitario         Float
  desconto              Float            @default(0)

  taxaIVAId             String
  taxaIVAPercentagem    Float

  base                  Float
  valorIVA              Float

  ordem                 Int              @default(1)

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  encomenda             EncomendaCliente @relation(fields: [encomendaId], references: [id], onDelete: Cascade)
  artigo                Artigo?          @relation(fields: [artigoId], references: [id])
}

// ============================================
// FATURAÇÃO RECORRENTE / AVENÇAS
// ============================================

enum FrequenciaSubscricao {
  SEMANAL
  MENSAL
  TRIMESTRAL
  SEMESTRAL
  ANUAL
}

enum EstadoSubscricao {
  ATIVA
  PAUSA
  CANCELADA
  CONCLUIDA
}

model Subscricao {
  id                    String               @id @default(cuid())
  clienteId             String
  empresaId             String?
  clienteNome           String
  clienteNif            String

  descricao             String
  frequencia            FrequenciaSubscricao @default(MENSAL)
  estado                EstadoSubscricao     @default(ATIVA)

  dataInicio            DateTime             @default(now())
  dataFim               DateTime?
  proximaEmissao        DateTime
  ultimaEmissao         DateTime?

  // Configuração da fatura a gerar
  serieId               String
  tipoDocumento         TipoDocumento        @default(FATURA)
  metodoPagamento       MetodoPagamento?     @default(TRANSFERENCIA)

  totalBase             Float                @default(0)
  totalIVA              Float                @default(0)
  totalLiquido          Float                @default(0)

  utilizadorId          String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  empresa               Empresa?             @relation(fields: [empresaId], references: [id])
  cliente               Cliente              @relation(fields: [clienteId], references: [id])
  serie                 Serie                @relation(fields: [serieId], references: [id])
  linhas                LinhaSubscricao[]

  @@index([clienteId])
  @@index([proximaEmissao])
}

model LinhaSubscricao {
  id                    String     @id @default(cuid())
  subscricaoId          String
  artigoId              String?

  codigoArtigo          String
  descricaoArtigo       String

  quantidade            Float
  precoUnitario         Float
  desconto              Float      @default(0)

  taxaIVAId             String
  taxaIVAPercentagem    Float

  base                  Float
  valorIVA              Float

  ordem                 Int        @default(1)

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  subscricao            Subscricao @relation(fields: [subscricaoId], references: [id], onDelete: Cascade)
  artigo                Artigo?    @relation(fields: [artigoId], references: [id])
}

// ============================================
// TESOURARIA E RECONCILIAÇÃO BANCÁRIA
// ============================================

model MovimentoBancario {
  id                String   @id @default(cuid())
  data              DateTime
  empresaId         String?
  descricao         String
  valor             Float
  referencia        String?
  conciliado        Boolean  @default(false)
  pagamentoId       String?  @unique

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  empresa           Empresa? @relation(fields: [empresaId], references: [id])
  pagamento         Pagamento? @relation(fields: [pagamentoId], references: [id])
}

// ============================================
// API E INTEGRAÇÕES
// ============================================

model ApiKey {
  id            String    @id @default(cuid())
  key           String    @unique
  nome          String    // Ex: "App Mobile", "E-commerce"
  utilizadorId  String?
  empresaId     String?
  permissao     String    @default("READ_WRITE") // READ, READ_WRITE
  ativo         Boolean   @default(true)
  ultimaUtilizacao DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  empresa       Empresa?  @relation(fields: [empresaId], references: [id])
}

model WebhookConfig {
  id            String    @id @default(cuid())
  url           String
  evento        String    // "DOCUMENTO.EMITIDO", "DOCUMENTO.PAGO", "*"
  descricao     String?
  secreto       String?   // Para assinatura do payload
  empresaId     String?
  ativo         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  empresa       Empresa?  @relation(fields: [empresaId], references: [id])
}
